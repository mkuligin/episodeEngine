APP_NAME=episodeEngine
WORKSPACE_DIR=.
STORAGE_DIR=storage
LOG_DIR=log
SYSTEM_PROMPT_FILE=system_prompt.md
MAX_ATTEMPTS=8

MODEL_MODE=auto
MODEL_PROVIDER=ollama
MODEL_NAME=qwen2.5-coder:7b
MODEL_FALLBACKS=openrouter:openai/gpt-4.1-mini,zai:glm-4.5-air
